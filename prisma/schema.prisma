// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== USER & AUTH ==========
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          Role      @default(USER)
  image         String?
  phone         String?
  bio           String?
  division      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  hrBotSessions HrBotSession[]
  leaveRequests LeaveRequest[]
  auditLogs     AuditLog[]
  journalEntries JournalEntry[] @relation("PostedJournalEntries")
  submittedFeedback SystemFeedback[] @relation("SubmittedFeedback")
  assignedFeedback  SystemFeedback[] @relation("AssignedFeedback")
}

model HrBotSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  messages  Json     // [{role: "user"|"assistant", content: string, timestamp: string}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model HrPolicy {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String   // "leave", "payroll", "onboarding", "regulation"
  embedding Unsupported("vector(1024)")? // pgvector for RAG
  metadata  Json     // {tags: ["policy", "hr"], version: "1.0"}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaveRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // e.g., "CREATE_LEAVE", "DELETE_POLICY"
  entity    String   // e.g., "LeaveRequest", "HrPolicy"
  entityId  String
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}

model FinanceAccount {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  category      AccountCategory
  normalBalance BalanceSide
  isSystem      Boolean         @default(false)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  journalLines JournalLine[]

  @@index([category])
}

model JournalEntry {
  id          String      @id @default(cuid())
  reference   String      @unique
  description String
  entryDate   DateTime
  totalDebit  Decimal     @db.Decimal(18, 2)
  totalCredit Decimal     @db.Decimal(18, 2)
  postedById  String?
  createdAt   DateTime    @default(now())

  postedBy User? @relation("PostedJournalEntries", fields: [postedById], references: [id])
  lines    JournalLine[]

  @@index([entryDate])
}

model JournalLine {
  id               String      @id @default(cuid())
  journalEntryId   String
  financeAccountId String
  side             BalanceSide
  amount           Decimal     @db.Decimal(18, 2)
  createdAt        DateTime    @default(now())

  journalEntry  JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  financeAccount FinanceAccount @relation(fields: [financeAccountId], references: [id])

  @@index([journalEntryId])
  @@index([financeAccountId])
  @@index([side])
}

model SystemFeedback {
  id             String           @id @default(cuid())
  module         FeedbackModule
  category       FeedbackCategory
  message        String           @db.Text
  status         FeedbackStatus   @default(OPEN)
  submittedById  String
  assignedToId   String?
  resolutionNote String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  submittedBy User @relation("SubmittedFeedback", fields: [submittedById], references: [id])
  assignedTo  User? @relation("AssignedFeedback", fields: [assignedToId], references: [id])

  @@index([module])
  @@index([status])
  @@index([submittedById])
}

// ========== ENUMS ==========
enum Role {
  ADMIN
  HR
  USER
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AccountCategory {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum BalanceSide {
  DEBIT
  CREDIT
}

enum FeedbackModule {
  QA
  SECOPS
  HR
  FINANCE
  GENERAL
}

enum FeedbackCategory {
  BUG
  UI_UX
  CONNECTION
  SECURITY
  TEST_CASE
  FEATURE_REQUEST
}

enum FeedbackStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}
